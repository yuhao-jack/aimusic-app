import 'dart:ui' as ui;
import 'dart:math' as math;

import 'package:flutter/material.dart';
import 'package:get/get.dart';
import 'package:aimusic_app/modules/create/task_progress_controller.dart';
import 'package:aimusic_app/theme/app_theme.dart';
import 'package:aimusic_app/widgets/animated_transitions.dart';

/// 渐变环形进度指示器 — 用 CustomPainter 绘制紫→青渐变环 + 辉光
class _GradientCircularProgress extends StatelessWidget {
  final double? percent; // 0.0 ~ 1.0, null → indeterminate
  final double strokeWidth;

  const _GradientCircularProgress({
    this.percent,
    this.strokeWidth = 10,
  });

  @override
  Widget build(BuildContext context) {
    return SizedBox(
      width: 140,
      height: 140,
      child: CustomPaint(
        painter: _RingPainter(
          percent: percent,
          strokeWidth: strokeWidth,
        ),
      ),
    );
  }
}

class _RingPainter extends CustomPainter {
  final double? percent;
  final double strokeWidth;

  _RingPainter({this.percent, required this.strokeWidth});

  @override
  void paint(Canvas canvas, Size size) {
    final center = Offset(size.width / 2, size.height / 2);
    final radius = (size.width - strokeWidth) / 2;
    const gradientColors = [Color(0xFF6366F1), Color(0xFF06B6D4)];

    // 1) 背景环
    final bgPaint = Paint()
      ..color = AppTheme.midDark.withValues(alpha: 0.6)
      ..style = PaintingStyle.stroke
      ..strokeWidth = strokeWidth
      ..strokeCap = StrokeCap.round;
    canvas.drawCircle(center, radius, bgPaint);

    // 2) 辉光环 (outer glow)
    if (percent != null && percent! > 0) {
      final glowPaint = Paint()
        ..shader = ui.Gradient.sweep(center, gradientColors)
        ..style = PaintingStyle.stroke
        ..strokeWidth = strokeWidth + 6
        ..strokeCap = StrokeCap.round
        ..maskFilter = const MaskFilter.blur(BlurStyle.normal, 8);
      canvas.drawArc(
        Rect.fromCircle(center: center, radius: radius),
        -math.pi / 2,
        2 * math.pi * percent!,
        false,
        glowPaint,
      );
    }

    // 3) 渐变进度环
    if (percent != null && percent! > 0) {
      final shader = ui.Gradient.sweep(center, gradientColors);
      final progressPaint = Paint()
        ..shader = shader
        ..style = PaintingStyle.stroke
        ..strokeWidth = strokeWidth
        ..strokeCap = StrokeCap.round;
      canvas.drawArc(
        Rect.fromCircle(center: center, radius: radius),
        -math.pi / 2,
        2 * math.pi * percent!,
        false,
        progressPaint,
      );
    } else {
      // indeterminate: 环
      final shader = ui.Gradient.sweep(center, gradientColors);
      final progressPaint = Paint()
        ..shader = shader
        ..style = PaintingStyle.stroke
        ..strokeWidth = strokeWidth
        ..strokeCap = StrokeCap.round;
      canvas.drawArc(
        Rect.fromCircle(center: center, radius: radius),
        -math.pi / 2,
        2 * math.pi * 0.75,
        false,
        progressPaint,
      );
    }
  }

  @override
  bool shouldRepaint(_RingPainter oldDelegate) =>
      oldDelegate.percent != percent;
}

class TaskProgressPage extends GetView<TaskProgressController> {
  const TaskProgressPage({super.key});

  @override
  Widget build(BuildContext context) {
    return Scaffold(
      backgroundColor: AppTheme.surface1,
      extendBodyBehindAppBar: true,
      appBar: AppBar(
        title: const Text(
          '任务进度',
          style: TextStyle(
            fontSize: 20,
            fontWeight: FontWeight.bold,
            color: AppTheme.textWhite,
          ),
        ),
        centerTitle: false,
        elevation: 0,
        backgroundColor: Colors.transparent,
        leading: IconButton(
          icon: const Icon(Icons.arrow_back_ios, color: AppTheme.textWhite),
          onPressed: () => Get.back(),
        ),
      ),
      body: Center(
        child: SingleChildScrollView(
          padding: const EdgeInsets.symmetric(horizontal: 24),
          child: Obx(() {
            if (controller.isLoading.value && controller.status.value.isEmpty) {
              return const Padding(
                padding: EdgeInsets.only(top: 80),
                child: Center(
                  child: CircularProgressIndicator(
                    color: AppTheme.primaryColor,
                    strokeWidth: 3,
                  ),
                ),
              );
            }

            return Column(
              mainAxisAlignment: MainAxisAlignment.center,
              children: [
                const SizedBox(height: 48),

                // --- 大居中玻璃卡片 ---
                Stack(
                  children: [
                    // 辐射渐变背景
                    IgnorePointer(
                      child: Container(
                        width: 340,
                        height: 420,
                        decoration: BoxDecoration(
                          shape: BoxShape.circle,
                          gradient: RadialGradient(
                            colors: [
                              AppTheme.primaryColor.withValues(alpha: 0.12),
                              AppTheme.surface1.withValues(alpha: 0),
                            ],
                            radius: 0.8,
                          ),
                        ),
                      ),
                    ),
                    // 玻璃卡片
                    ClipRRect(
                      borderRadius: BorderRadius.circular(AppTheme.radiusLarge),
                      child: BackdropFilter(
                        filter: ui.ImageFilter.blur(sigmaX: 16, sigmaY: 16),
                        child: Container(
                          width: 340,
                          padding: const EdgeInsets.symmetric(
                            horizontal: 32,
                            vertical: 40,
                          ),
                          decoration: BoxDecoration(
                            color: AppTheme.surfaceElevated.withValues(alpha: 0.65),
                            borderRadius:
                                BorderRadius.circular(AppTheme.radiusLarge),
                            border: Border.all(
                              color: AppTheme.borderSubtle.withValues(alpha: 0.35),
                              width: 0.5,
                            ),
                          ),
                          child: Column(
                            mainAxisSize: MainAxisSize.min,
                            children: [
                              if (controller.status.value == "pending" ||
                                  controller.status.value == "processing" ||
                                  controller.status.value == "running")
                                _buildProcessingState(),
                              if (controller.status.value == "completed" ||
                                  controller.status.value == "success")
                                _buildCompletedState(),
                              if (controller.status.value == "failed")
                                _buildFailedState(),
                            ],
                          ),
                        ),
                      ),
                    ),
                  ],
                ),

                const SizedBox(height: 48),
              ],
            );
          }),
        ),
      ),
    );
  }

  // ===================================================================
  // 处理中状态
  // ===================================================================
  Widget _buildProcessingState() {
    return FadeInWidget(
      child: Column(
        mainAxisSize: MainAxisSize.min,
        children: [
          // --- 渐变进度环 ---
          SizedBox(
            width: 140,
            height: 140,
            child: Stack(
              alignment: Alignment.center,
              children: [
                _GradientCircularProgress(
                  percent: controller.progressPercent.value > 0
                      ? controller.progressPercent.value / 100.0
                      : null,
                  strokeWidth: 10,
                ),
                // 中心百分比
                if (controller.progressPercent.value > 0)
                  Text(
                    '${controller.progressPercent.value}%',
                    style: const TextStyle(
                      fontSize: 26,
                      fontWeight: FontWeight.bold,
                      color: AppTheme.textWhite,
                      letterSpacing: -0.5,
                    ),
                  )
                else
                  const Icon(
                    Icons.hourglass_empty_rounded,
                    color: AppTheme.textSilver,
                    size: 36,
                  ),
              ],
            ),
          ),

          const SizedBox(height: 28),

          // --- 状态文本 ---
          Text(
            controller.status.value == "pending" ? "任务排队中" : "正在生成中",
            style: const TextStyle(
              fontSize: 21,
              fontWeight: FontWeight.w700,
              color: AppTheme.textWhite,
              letterSpacing: 0.3,
            ),
          ),

          const SizedBox(height: 6),

          // --- 进度详情 ---
          if (controller.progress.value.isNotEmpty)
            Container(
              margin: const EdgeInsets.only(top: 4),
              padding:
                  const EdgeInsets.symmetric(horizontal: 16, vertical: 12),
              decoration: BoxDecoration(
                color: AppTheme.surface2.withValues(alpha: 0.6),
                borderRadius:
                    BorderRadius.circular(AppTheme.radiusComfortable),
                border: Border.all(
                  color: AppTheme.borderSubtle.withValues(alpha: 0.3),
                  width: 0.5,
                ),
              ),
              child: Row(
                mainAxisSize: MainAxisSize.min,
                children: [
                  SizedBox(
                    width: 14,
                    height: 14,
                    child: CircularProgressIndicator(
                      strokeWidth: 1.5,
                      valueColor: const AlwaysStoppedAnimation<Color>(
                          AppTheme.primaryColor),
                    ),
                  ),
                  const SizedBox(width: 10),
                  Flexible(
                    child: Text(
                      controller.progress.value,
                      style: const TextStyle(
                        fontSize: 13,
                        color: AppTheme.textLightGray,
                        height: 1.4,
                      ),
                    ),
                  ),
                ],
              ),
            ),
        ],
      ),
    );
  }

  // ===================================================================
  // 完成状态
  // ===================================================================
  Widget _buildCompletedState() {
    return FadeInWidget(
      child: Column(
        mainAxisSize: MainAxisSize.min,
        children: [
          // --- 渐变勾选图标 ---
          Container(
            width: 110,
            height: 110,
            decoration: BoxDecoration(
              shape: BoxShape.circle,
              gradient: const SweepGradient(
                colors: [
                  AppTheme.brandPurple,
                  AppTheme.brandPink,
                  AppTheme.brandPurple,
                ],
              ),
              boxShadow: [
                BoxShadow(
                  color: AppTheme.primaryColor.withValues(alpha: 0.25),
                  blurRadius: 24,
                  offset: const Offset(0, 0),
                ),
              ],
            ),
            child: const Icon(
              Icons.check_rounded,
              color: AppTheme.textWhite,
              size: 56,
            ),
          ),

          const SizedBox(height: 28),

          // --- 标题 ---
          const Text(
            '生成完成！',
            style: TextStyle(
              fontSize: 26,
              fontWeight: FontWeight.bold,
              color: AppTheme.textWhite,
              letterSpacing: 0.5,
            ),
          ),

          const SizedBox(height: 8),

          const Text(
            '你的AI音乐已经准备好了',
            style: TextStyle(
              fontSize: 15,
              color: AppTheme.textSilver,
              letterSpacing: 0.2,
            ),
          ),

          const SizedBox(height: 36),

          // --- 主要按钮：渐变 pill ---
          SizedBox(
            width: double.infinity,
            child: ElasticButton(
              onTap: () => controller.goToMusicDetail(),
              child: Container(
                padding: const EdgeInsets.symmetric(vertical: 16),
                decoration: BoxDecoration(
                  gradient: AppTheme.crystalTechGradient,
                  borderRadius:
                      BorderRadius.circular(AppTheme.radiusFullPill),
                  boxShadow: [
                    BoxShadow(
                      color: AppTheme.primaryColor.withValues(alpha: 0.35),
                      blurRadius: 16,
                      offset: const Offset(0, 6),
                    ),
                  ],
                ),
                child: const Center(
                  child: Text(
                    '查看歌曲',
                    style: TextStyle(
                      fontSize: 16,
                      fontWeight: FontWeight.bold,
                      color: AppTheme.textWhite,
                      letterSpacing: 0.5,
                    ),
                  ),
                ),
              ),
            ),
          ),

          const SizedBox(height: 14),

          // --- 次要按钮：文字链接 ---
          GestureDetector(
            onTap: () => Get.back(),
            child: Container(
              padding: const EdgeInsets.symmetric(vertical: 8, horizontal: 16),
              child: const Text(
                '返回创作页',
                style: TextStyle(
                  color: AppTheme.textDim,
                  fontSize: 14,
                  letterSpacing: 0.3,
                ),
              ),
            ),
          ),
        ],
      ),
    );
  }

  // ===================================================================
  // 失败状态
  // ===================================================================
  Widget _buildFailedState() {
    return FadeInWidget(
      child: Column(
        mainAxisSize: MainAxisSize.min,
        children: [
          // --- 错误图标 + 红色微光 ---
          Container(
            width: 110,
            height: 110,
            decoration: BoxDecoration(
              shape: BoxShape.circle,
              color: AppTheme.surface3,
              border: Border.all(
                color: AppTheme.errorColor.withValues(alpha: 0.25),
                width: 2,
              ),
              boxShadow: [
                BoxShadow(
                  color: AppTheme.errorColor.withValues(alpha: 0.15),
                  blurRadius: 28,
                  offset: const Offset(0, 0),
                ),
              ],
            ),
            child: const Icon(
              Icons.error_outline_rounded,
              color: AppTheme.errorColor,
              size: 52,
            ),
          ),

          const SizedBox(height: 28),

          // --- 标题 ---
          const Text(
            '生成失败',
            style: TextStyle(
              fontSize: 26,
              fontWeight: FontWeight.bold,
              color: AppTheme.textWhite,
              letterSpacing: 0.5,
            ),
          ),

          const SizedBox(height: 12),

          // --- 错误信息玻璃卡片 ---
          if (controller.progress.value.isNotEmpty)
            Container(
              width: double.infinity,
              padding: const EdgeInsets.symmetric(horizontal: 16, vertical: 14),
              decoration: BoxDecoration(
                color: AppTheme.errorColor.withValues(alpha: 0.06),
                borderRadius:
                    BorderRadius.circular(AppTheme.radiusComfortable),
                border: Border.all(
                  color: AppTheme.errorColor.withValues(alpha: 0.12),
                  width: 0.5,
                ),
              ),
              child: Row(
                crossAxisAlignment: CrossAxisAlignment.start,
                children: [
                  Padding(
                    padding: const EdgeInsets.only(top: 1),
                    child: Icon(
                      Icons.info_outline_rounded,
                      size: 16,
                      color: AppTheme.errorColor.withValues(alpha: 0.7),
                    ),
                  ),
                  const SizedBox(width: 10),
                  Expanded(
                    child: Text(
                      controller.progress.value,
                      style: TextStyle(
                        fontSize: 13,
                        color: AppTheme.textSilver.withValues(alpha: 0.8),
                        height: 1.45,
                      ),
                    ),
                  ),
                ],
              ),
            )
          else
            Text(
              '请稍后重试',
              style: TextStyle(
                fontSize: 14,
                color: AppTheme.textLightGray.withValues(alpha: 0.8),
                letterSpacing: 0.2,
              ),
            ),

          const SizedBox(height: 36),

          // --- 操作按钮 ---
          SizedBox(
            width: double.infinity,
            child: ElasticButton(
              onTap: () => Get.back(),
              child: Container(
                padding: const EdgeInsets.symmetric(vertical: 16),
                decoration: BoxDecoration(
                  color: AppTheme.surface3,
                  borderRadius:
                      BorderRadius.circular(AppTheme.radiusFullPill),
                  border: Border.all(
                    color: AppTheme.borderSubtle.withValues(alpha: 0.5),
                    width: 0.5,
                  ),
                  boxShadow: [
                    BoxShadow(
                      color: AppTheme.errorColor.withValues(alpha: 0.08),
                      blurRadius: 12,
                      offset: const Offset(0, 4),
                    ),
                  ],
                ),
                child: Center(
                  child: Row(
                    mainAxisSize: MainAxisSize.min,
                    children: [
                      Icon(
                        Icons.refresh_rounded,
                        size: 18,
                        color: AppTheme.textSilver.withValues(alpha: 0.9),
                      ),
                      const SizedBox(width: 8),
                      const Text(
                        '返回重试',
                        style: TextStyle(
                          fontSize: 16,
                          fontWeight: FontWeight.w600,
                          color: AppTheme.textSilver,
                          letterSpacing: 0.5,
                        ),
                      ),
                    ],
                  ),
                ),
              ),
            ),
          ),
        ],
      ),
    );
  }
}
