              // ===== Recent Creations Header =====
              FadeInWidget(
                delayMs: 160 + 4 * 80 + 60,
                child: Padding(
                  padding: const EdgeInsets.only(left: 20),
                  child: Row(
                    children: [
                      Container(
                        width: 3,
                        height: 18,
