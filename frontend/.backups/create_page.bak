                          foregroundColor: AppTheme.primaryColor.withValues(alpha: 0.7),
                          padding: const EdgeInsets.symmetric(horizontal: 12),
                          textStyle: const TextStyle(
                            fontSize: 12,
                            fontWeight: FontWeight.w600,
                            letterSpacing: 0.3,
                          ),
                        ),
                        child: const Text('查看全部'),
                      ),
                    ],
                  ),
