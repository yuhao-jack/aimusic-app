                          gradient: AppTheme.primaryToSecondary,
                          borderRadius: BorderRadius.circular(2),
                        ),
                      ),
                      const SizedBox(width: 10),
                      const Text(
                        '最近创作',
                        style: TextStyle(
                          fontSize: 18,
                          fontWeight: FontWeight.w700,
                          color: AppTheme.textWhite,
                          letterSpacing: 0.3,
                        ),
                      ),
                      const Spacer(),
                      TextButton(
                        onPressed: () {},
