import 'package:flutter/material.dart';
import 'package:get/get.dart';
import 'package:aimusic_app/theme/app_theme.dart';
import 'package:aimusic_app/widgets/animated_transitions.dart';
import 'create_post_controller.dart';

class CreatePostPage extends GetView<CreatePostController> {
  const CreatePostPage({super.key});

  @override
  Widget build(BuildContext context) {
    return Scaffold(
      backgroundColor: AppTheme.nearBlack,
      appBar: AppBar(
        title: const Text(
          '发布动态',
          style: TextStyle(
            fontSize: 20,
            fontWeight: FontWeight.bold,
            color: AppTheme.textWhite,
          ),
        ),
        centerTitle: false,
        elevation: 0,
        backgroundColor: Colors.transparent,
        leading: IconButton(
          onPressed: () => Get.back(),
          icon: const Icon(Icons.arrow_back_ios, color: AppTheme.textWhite),
        ),
        actions: [
          Obx(() => TextButton(
            onPressed: controller.isLoading.value ? null : () => controller.publishPost(),
            child: controller.isLoading.value
                ? const SizedBox(
                    width: 20,
                    height: 20,
                    child: CircularProgressIndicator(
                      color: AppTheme.textWhite,
                      strokeWidth: 2,
                    ),
                  )
                : Container(
                    padding: const EdgeInsets.symmetric(
                      horizontal: 16,
                      vertical: 6,
                    ),
                    decoration: BoxDecoration(
                      color: AppTheme.primaryColor,
                      borderRadius: BorderRadius.circular(AppTheme.radiusFullPill),
                    ),
                    child: const Text(
                      '发布',
                      style: TextStyle(
                        color: AppTheme.textWhite,
                        fontSize: 14,
                        fontWeight: FontWeight.w600,
                      ),
                    ),
                  ),
          )),
          const SizedBox(width: 8),
        ],
      ),
      body: SingleChildScrollView(
        padding: const EdgeInsets.symmetric(horizontal: 20, vertical: 16),
        child: Column(
          crossAxisAlignment: CrossAxisAlignment.start,
          children: [
            FadeInWidget(
              child: Container(
                decoration: BoxDecoration(
                  color: AppTheme.darkSurface,
                  borderRadius: BorderRadius.circular(AppTheme.radiusLarge),
                ),
                child: TextField(
                  controller: controller.contentController,
                  decoration: const InputDecoration(
                    hintText: '分享你的音乐想法...',
                    hintStyle: TextStyle(color: AppTheme.textDarkGray),
                    border: InputBorder.none,
                    alignLabelWithHint: true,
                    counterText: '',
                    contentPadding: EdgeInsets.all(20),
                  ),
                  maxLines: 8,
                  minLines: 5,
                  maxLength: 500,
                  textInputAction: TextInputAction.newline,
                  autofocus: true,
                  style: const TextStyle(
                    fontSize: 16,
                    height: 1.6,
                    color: AppTheme.textWhite,
                  ),
                ),
              ),
            ),
            const SizedBox(height: 24),
            // 添加图片标题
            FadeInWidget(
              delayMs: 80,
              child: Column(
                crossAxisAlignment: CrossAxisAlignment.start,
                children: [
                  const Text(
                    '添加图片',
                    style: TextStyle(
                      fontSize: 16,
                      fontWeight: FontWeight.w600,
                      color: AppTheme.textWhite,
                    ),
                  ),
                  const SizedBox(height: 16),
                  // 添加图片按钮
                  Obx(
                    () => Wrap(
                      spacing: 12,
                      runSpacing: 12,
                      children: [
                        ...controller.images.map((url) {
                          return Stack(
                            children: [
                              ClipRRect(
                                borderRadius: BorderRadius.circular(AppTheme.radiusMedium),
                                child: Image.network(
                                  url,
                                  width: 90,
                                  height: 90,
                                  fit: BoxFit.cover,
                                ),
                              ),
                              Positioned(
                                top: 4,
                                right: 4,
                                child: ElasticButton(
                                  onTap: () => controller.removeImage(url),
                                  child: Container(
                                    padding: const EdgeInsets.all(4),
                                    decoration: const BoxDecoration(
                                      color: Colors.black54,
                                      shape: BoxShape.circle,
                                    ),
                                    child: const Icon(
                                      Icons.close,
                                      color: Colors.white,
                                      size: 16,
                                    ),
                                  ),
                                ),
                              ),
                            ],
                          );
                        }).toList(),
                        if (controller.images.length < 9)
                          ElasticButton(
                            onTap: controller.addImage,
                            child: Container(
                              width: 90,
                              height: 90,
                              decoration: BoxDecoration(
                                color: AppTheme.midDark,
                                borderRadius: BorderRadius.circular(AppTheme.radiusMedium),
                              ),
                              child: Column(
                                mainAxisAlignment: MainAxisAlignment.center,
                                children: [
                                  Icon(
                                    Icons.add_photo_alternate_outlined,
                                    size: 36,
                                    color: AppTheme.textDarkGray,
                                  ),
                                  const SizedBox(height: 4),
                                  Text(
                                    '添加',
                                    style: TextStyle(
                                      fontSize: 12,
                                      color: AppTheme.textDarkGray,
                                    ),
                                  ),
                                ],
                              ),
                            ),
                          ),
                      ],
                    ),
                  ),
                ],
              ),
            ),
          ],
        ),
      ),
    );
  }
}
